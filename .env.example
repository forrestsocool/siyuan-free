SIYUAN_IMAGE=ghcr.io/forrestsocool/siyuan-free:codex-unlock-extra-services
SIYUAN_EXTRA_IMAGE=ghcr.io/forrestsocool/siyuan-extra:codex-unlock-extra-services

SIYUAN_WORKSPACE=/share/Container/siyuan/workspace
SIYUAN_ACCESS_AUTH_CODE=siyuan1896
SIYUAN_PORT=6806
SIYUAN_EXTRA_PORT=6810

TZ=Asia/Shanghai
PUID=1000
PGID=100

# SiYuan Settings - About - API Token. Required for /clip and WeChat reminders.
SIYUAN_TOKEN=

# Optional S3-compatible asset image bed.
S3_ENDPOINT_URL=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=siyuan-assets
S3_FORCE_PATH_STYLE=true
ASSET_PUBLIC_BASE=

# Optional Work WeChat robot webhook.
WECHAT_WEBHOOK_URL=
WECHAT_WEBHOOK_TYPE=work_wechat

REMINDER_INTERVAL_SECONDS=60
ASSET_SCAN_INTERVAL_SECONDS=300
